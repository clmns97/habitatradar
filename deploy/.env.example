# Copy to deploy/.env on the VPS and fill in. Keep .env out of git (gitignored).

# Public hostname for the API (A record -> VPS public IP). Used by Caddy + TLS.
API_DOMAIN=api.example.com

# Allowed CORS origin (the deployed frontend).
FRONTEND_ORIGIN=https://REDACTED_ORIGIN

# Backend connects with the READ-ONLY role over the shared Docker network.
DATABASE_URL=postgresql+asyncpg://REDACTED_ROLE:CHANGE_ME@postgis:5432/habitatradar

# ETL connects with the WRITE role (owner of the public schema).
IMPORT_DATABASE_URL=postgresql://REDACTED_ROLE:CHANGE_ME@postgis:5432/habitatradar

# Optional ETL tuning.
WFS_URL=https://geodienste.bfn.de/ogc/wfs/schutzgebiet
ETL_PARALLEL=3
