# Copy to deploy/.env on the server and fill in. Keep .env out of git (gitignored).

# Public hostname for the API (A record -> server). Used by Caddy + TLS.
API_DOMAIN=<your-api-hostname>

# Allowed CORS origin (the deployed frontend).
FRONTEND_ORIGIN=<your-frontend-origin>

# Backend connects with the READ-ONLY role over the shared Docker network.
DATABASE_URL=postgresql+asyncpg://<read_role>:<password>@<db_host>:5432/<db_name>

# ETL connects with the WRITE role (owner of the public schema).
IMPORT_DATABASE_URL=postgresql://<write_role>:<password>@<db_host>:5432/<db_name>

# Optional ETL tuning.
WFS_URL=https://geodienste.bfn.de/ogc/wfs/schutzgebiet
ETL_PARALLEL=3
